Set-Content .gitignore @"
# Dependencies
node_modules/
.pnpm-store/

# Next.js build output
.next/
out/
build/

# Debug and Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

# Sensitive Environment Keys (Crucial for Supabase security)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# System Files
.DS_Store
Thumbs.db
"@